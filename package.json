{
  "name": "melon-lang",
  "version": "1.0.12",
  "scripts": {
    "test": "jest --verbose",
    "build": "tsc",
    "dev": "tsc --watch",
    "build:webport": "webpack --config webport/webpack.config.js",
    "build:shortcut": "node scripts/inject-version.mjs && cd shortcut && cherri melon.cherri",
    "build:shortcut:dev": "cd shortcut && cherri melon.cherri",
    "start": "node dist/src/cli.js",
    "melon": "node dist/src/cli.js"
  },
  "description": "A language designed for creating automations for Apple devices that run blazingly fast ⚡",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "melon": "dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "author": "Eren Yenigul",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "es6-shim": "^0.35.8",
    "reflect-metadata": "^0.1.13",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.4",
    "@types/node": "^20.16.1",
    "@types/webpack": "^5.28.5",
    "html-inline-script-webpack-plugin": "^3.2.1",
    "html-minimizer-webpack-plugin": "^6.0.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.6.4",
    "jest-environment-jsdom": "^29.6.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "webpack": "^5.108.4",
    "webpack-cli": "^5.1.4"
  }
}
